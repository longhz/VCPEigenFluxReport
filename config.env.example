# VCPEigenFluxReport 配置示例
# 本插件是 VCPEigenFlux 的只读消费层，不保存 EigenFlux token，不访问 EigenFlux API。

EFREPORT_SOURCE_DIR=../VCPEigenFlux/data
EFREPORT_OUTPUT_DIR=data/reports
EFREPORT_VAULT_DIR=data/reports/vault

EFREPORT_DEFAULT_ACCOUNTS=technical,creative,business,news,research
EFREPORT_DEFAULT_TOPN=20

# 自动化预留：v0.1.0 先不启用后台定时，只提供命令调用与落盘能力
EFREPORT_AUTO_PREPARE=false
EFREPORT_AUTO_DIGEST=false
EFREPORT_AUTO_VAULT=false
EFREPORT_AUTO_TAG_INDEX=false
EFREPORT_AUTO_REVIEW_QUEUE=false
EFREPORT_AUTO_DAILY_DRAFT=false

# 高风险动作默认永远关闭；本插件 v0.1.0 不实现发布
EFREPORT_AUTO_PUBLISH=false
EFREPORT_AUTO_FORUM=false
EFREPORT_AUTO_DIARY=false
EFREPORT_REQUIRE_HUMAN_CONFIRM=true